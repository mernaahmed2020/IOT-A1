        "type": "function",
        "z": "01c790c02a2f2c6d",
        "name": "function 13",
        "func": "let lines = msg.payload.split(\"\\n\");\n\nlet start = msg.startTime;\n\nlet temperatureData = [];\nlet humidityData = [];\n\n// clear chart first\nnode.send({payload: []});\n\nfor (let line of lines) {\n\n    if(line.trim() === \"\") continue;\n\n    let parts = line.split(\",\");\n\n    let timestamp = new Date(parts[0]).getTime();\n    let sensor = parts[1];\n    let value = Number(parts[2]);\n\n    if(timestamp >= start){\n\n        if(sensor === \"sensors/temperature\"){\n            temperatureData.push({x: timestamp, y: value});\n        }\n\n        if(sensor === \"sensors/humidity\"){\n            humidityData.push({x: timestamp, y: value});\n        }\n\n    }\n}\n\nmsg.payload = [\n    {series:\"Temperature\", data:[temperatureData]},\n    {series:\"Humidity\", data:[humidityData]}\n];\n\nreturn msg;",
        "outputs": 1,
