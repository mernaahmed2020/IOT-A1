    {
        "id": "d2e43d4c8b49108b",
        "type": "function",
        "z": "01c790c02a2f2c6d",
        "name": "function 11",
        "func": "let lines = msg.payload.split(\"\\n\");\n\nlet now = Date.now();\nlet last24h = now - (24 * 60 * 60 * 1000);\n\nlet filtered = [];\n\nfor (let line of lines) {\n\n    if(line.trim() === \"\") continue;\n\n    let parts = line.split(\",\");\n\n    let timestamp = new Date(parts[0]).getTime();\n\n    if(timestamp >= last24h){\n        filtered.push(line);\n    }\n\n}\n\nmsg.payload = filtered.join(\"\\n\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2150,
        "y": 480,
        "wires": [
            [
                "f6f2093ac9132a68",
                "7bc8f0e6808fc619"
            ]
        ]
    },
    {
        "id": "f6f2093ac9132a68",
        "type": "ui_template",
        "z": "01c790c02a2f2c6d",
        "group": "c9c46cb42d153f46",
        "name": "",
        "order": 8,
        "width": 0,
        "height": 0,
        "format": "<script>\n    (function(scope){\n\n    scope.$watch('msg', function(msg){\n\n        if(!msg) return;\n\n        var data = msg.payload;\n\n        var blob = new Blob([data], {type: \"text/csv\"});\n\n        var url = URL.createObjectURL(blob);\n\n        var a = document.createElement(\"a\");\n\n        a.href = url;\n\n        a.download = \"last24hours_data.csv\";\n\n        document.body.appendChild(a);\n\n        a.click();\n\n        document.body.removeChild(a);\n\n    });\n\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
